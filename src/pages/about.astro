---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import photo from '../assets/akash.jpg';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description="A little bit about Akash Agrawal." />
	</head>
	<body>
		<Header />
		<main>
			<article class="about">
				<div class="avatar">
					<Image src={photo} alt="Akash Agrawal" width={120} height={120} />
				</div>
				<p class="eyebrow">About · Solutions Architect</p>
				<h1>Akash Agrawal</h1>
				<div class="prose">
					<p>
						I'm Akash — a solutions architect who has spent 15 years designing, building and
						shipping software end to end. I've worked across the stack: distributed backends and
						APIs, cloud platforms, web frontends, native mobile apps, and command-line tools.
					</p>
					<p>
						I like reading and tinkering with programming languages (Elixir, Ruby, JavaScript,
						Swift, Lisp), editors (Emacs, Vim, VS Code), tools (Docker, Kubernetes), and frameworks
						(Angular, React, SwiftUI, Phoenix). Away from the keyboard I'm usually doing <a
							href="https://www.instagram.com/akshagrwl"
							target="_blank"
							rel="noopener">photography</a
						>, playing video games, or reading sci-fi and fantasy.
					</p>
					<p>
						This site is where I keep my writing and a few of the things I've built. You can find me
						on <a href="https://github.com/akagr" target="_blank" rel="noopener">GitHub</a> and <a
							href="https://twitter.com/akshagrwl"
							target="_blank"
							rel="noopener">Twitter/X</a
						>.
					</p>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		text-align: center;
	}
	.avatar {
		width: 120px;
		height: 120px;
		margin: 0 auto 1.5rem;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: var(--shadow);
		border: 4px solid var(--bg-raised);
	}
	.avatar :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.about h1 {
		margin-bottom: 2rem;
	}
	.prose {
		text-align: left;
		max-width: 34rem;
		margin: 0 auto;
	}
</style>
