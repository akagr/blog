---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import photo from '../assets/akash.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 4);

const projects = [
	{
		name: 'tax-tools',
		tagline:
			'A Go CLI that turns Interactive Brokers holdings into a ready-to-file Indian Schedule FA (Foreign Assets) ITR report — calendar-year basis, SBI TTBR conversion, exact peak values, and a full audit trail.',
		url: 'https://github.com/akagr/tax-tools',
		meta: 'Go · CLI',
	},
	{
		name: 'GaadiLog',
		tagline:
			'A local-first car service & expense tracker for Indian vehicle owners — fuel, service and documents, no account required. Native SwiftUI + Jetpack Compose apps, live on the App Store and Google Play.',
		url: 'https://github.com/akagr/car-log-app',
		meta: 'SwiftUI · Compose · iOS + Android',
	},
	{
		name: 'gaadilog-site',
		tagline: 'The marketing site for GaadiLog — designed and shipped from scratch on GitHub Pages.',
		url: 'https://akagr.github.io/gaadilog-site/',
		meta: 'Website · CSS',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="avatar">
					<Image src={photo} alt="Akash Agrawal" width={128} height={128} />
				</div>
				<p class="eyebrow">Solutions Architect · 15 Years</p>
				<h1>Akash Agrawal</h1>
				<p class="lead">
					I design, build and scale software end to end — distributed systems and cloud platforms,
					web and native mobile, and the occasional sharp little tool. I like things that are simple
					to reason about and built to last.
				</p>
				<div class="cta">
					<a class="button" href="/blog">Read the writing</a>
					<a class="button ghost" href="/about">About me</a>
				</div>
			</section>

			<section class="section">
				<h2>Selected work</h2>
				<div class="projects">
					{
						projects.map((project) => (
							<a class="project" href={project.url} target="_blank" rel="noopener">
								<div class="project-head">
									<h3>{project.name}</h3>
									<span class="meta">{project.meta}</span>
								</div>
								<p>{project.tagline}</p>
							</a>
						))
					}
				</div>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Writing</h2>
					<a class="all" href="/blog">All posts →</a>
				</div>
				<ul class="posts">
					{
						recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-desc">{post.data.description}</span>
									<FormattedDate date={post.data.pubDate} />
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding-bottom: 3.5rem;
		border-bottom: 1px solid var(--line);
	}
	.avatar {
		width: 128px;
		height: 128px;
		margin: 0 auto 1.5rem;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: var(--shadow);
		border: 4px solid var(--bg-raised);
	}
	.avatar :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.hero h1 {
		margin-bottom: 1rem;
	}
	.lead {
		max-width: 34rem;
		margin: 0 auto;
		font-size: 1.2rem;
		color: var(--text-soft);
	}
	.cta {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}
	.button {
		display: inline-block;
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 0.95rem;
		padding: 0.6rem 1.3rem;
		border-radius: 999px;
		background: var(--text);
		color: var(--bg);
		text-decoration: none;
		border: 1px solid var(--text);
		transition: 0.15s ease;
	}
	.button:hover {
		opacity: 0.85;
		color: var(--bg);
	}
	.button.ghost {
		background: transparent;
		color: var(--text);
		border-color: var(--line);
	}
	.button.ghost:hover {
		border-color: var(--text);
		color: var(--text);
		opacity: 1;
	}

	.section {
		padding-top: 3.5rem;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
	}
	.all {
		font-size: 0.9rem;
		text-decoration: none;
		color: var(--muted);
		white-space: nowrap;
	}
	.all:hover {
		color: var(--accent);
	}

	.projects {
		display: grid;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}
	.project {
		display: block;
		padding: 1.5rem 0;
		border-top: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
	}
	.project:hover .project-head h3 {
		color: var(--accent);
	}
	.project-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.project-head h3 {
		margin: 0;
		transition: 0.15s ease;
	}
	.meta {
		font-size: 0.82rem;
		color: var(--muted);
		white-space: nowrap;
		text-align: right;
	}
	.project p {
		margin: 0.5rem 0 0;
		color: var(--text-soft);
		font-size: 0.98rem;
	}

	.posts {
		list-style: none;
		margin: 0.5rem 0 0;
		padding: 0;
	}
	.posts li {
		border-top: 1px solid var(--line);
	}
	.posts a {
		display: block;
		padding: 1.4rem 0;
		text-decoration: none;
		color: inherit;
	}
	.post-title {
		display: block;
		font-family: var(--font-serif);
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--text);
		line-height: 1.2;
		transition: 0.15s ease;
	}
	.posts a:hover .post-title {
		color: var(--accent);
	}
	.post-desc {
		display: block;
		color: var(--text-soft);
		font-size: 0.98rem;
		margin: 0.35rem 0 0.5rem;
	}
	.posts :global(time) {
		font-size: 0.82rem;
		color: var(--muted);
	}
</style>
