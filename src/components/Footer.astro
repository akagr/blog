---
const today = new Date();
const links = [
	{ label: 'GitHub', href: 'https://github.com/akagr' },
	{ label: 'Twitter/X', href: 'https://twitter.com/akshagrwl' },
	{ label: 'Instagram', href: 'https://www.instagram.com/akshagrwl' },
	{ label: 'RSS', href: '/rss.xml' },
];
---

<footer>
	<div class="inner">
		<nav class="links">
			{
				links.map((l) => (
					<a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
						{l.label}
					</a>
				))
			}
		</nav>
		<p class="copy">© {today.getFullYear()} Akash Agrawal · Built with Astro</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--line);
		margin-top: 2rem;
	}
	.inner {
		width: var(--wide-width);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		padding: 2.5rem 0;
		text-align: center;
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1.4rem;
		margin-bottom: 0.9rem;
	}
	.links a {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.92rem;
	}
	.links a:hover {
		color: var(--text);
	}
	.copy {
		margin: 0;
		font-size: 0.85rem;
		color: var(--muted);
	}
</style>
