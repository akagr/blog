---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="bar">
		<a href="/" class="brand">Akash Agrawal</a>
		<nav>
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Writing</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<button id="theme-toggle" type="button" aria-label="Toggle color theme">
				<svg class="sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"
					><path
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						d="M12 3v2m0 14v2M3 12h2m14 0h2M5.6 5.6l1.4 1.4m10 10l1.4 1.4m0-12.8l-1.4 1.4m-10 10l-1.4 1.4"
					></path><circle cx="12" cy="12" r="4" fill="currentColor"></circle></svg
				>
				<svg class="moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"
					><path
						fill="currentColor"
						d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg
				>
			</button>
		</nav>
	</div>
</header>

<script is:inline>
	(function () {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;
		btn.addEventListener('click', function () {
			const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			localStorage.setItem('theme', next);
		});
	})();
</script>

<style>
	header {
		border-bottom: 1px solid var(--line-soft);
		background: color-mix(in srgb, var(--bg) 88%, transparent);
		backdrop-filter: blur(10px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	.bar {
		width: var(--wide-width);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 66px;
	}
	.brand {
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.01em;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.92rem;
	}
	nav :global(a) {
		color: var(--muted);
		text-decoration: none;
		padding: 0.4rem 0.7rem;
		border-radius: 6px;
	}
	nav :global(a:hover) {
		color: var(--text);
	}
	nav :global(a.active) {
		color: var(--text);
	}
	#theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-left: 0.4rem;
		width: 34px;
		height: 34px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--bg-raised);
		color: var(--text-soft);
		cursor: pointer;
		transition: 0.15s ease;
	}
	#theme-toggle:hover {
		color: var(--text);
		border-color: var(--muted);
	}
	.moon {
		display: none;
	}
	:global([data-theme='dark']) .sun {
		display: none;
	}
	:global([data-theme='dark']) .moon {
		display: block;
	}
</style>
